rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // Users Collection
    // =====================================================================
    match /users/{userId} {
      // ✅ [수정] 본인만 자신의 전체 문서를 읽고 쓸 수 있도록 허용합니다.
      // 이것이 실시간 프로필 업데이트 리스너 오류를 해결합니다.
      allow read, write: if request.auth.uid == userId;

      // Admin 사용자는 모든 사용자의 정보를 조회할 수 있습니다.
      allow get: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // =====================================================================
    // Posts Collection
    // =====================================================================
    match /posts/{postId} {
      // 누구나 게시물을 읽을 수 있습니다. (향후 더 세분화 가능)
      allow read: if true;
      
      // 본인 또는 Admin만 게시물을 생성, 수정, 삭제할 수 있습니다.
      allow create, update, delete: if request.auth.uid == resource.data.authorId 
                                      || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // =====================================================================
    // Notices Collection
    // =====================================================================
    match /notices/{noticeId} {
      // 누구나 공지사항을 읽을 수 있습니다.
      allow read: if true;
      
      // Admin만 공지사항을 생성, 수정, 삭제할 수 있습니다.
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // =====================================================================
    // System Collection (e.g., for stats)
    // =====================================================================
    match /system/{docId} {
       // Admin만 시스템 문서에 접근할 수 있습니다.
      allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}