rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ===== 공통 헬퍼 ===== */
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    // Custom Claims: roles:["admin","moderator"] 또는 token.admin=true 지원
    function hasRole(role) {
      return isSignedIn()
        && request.auth.token.roles is list
        && role in request.auth.token.roles;
    }
    function isAdmin() {
      return (request.auth.token.admin == true) || hasRole('admin') || hasRole('moderator');
    }
    function stringMax(s, n) {
      return s is string && s.size() <= n;
    }
    function boolField(b) {
      return b is bool;
    }
    function onlyKeysAllowed(data, keys) {
      return data.keys().hasOnly(keys);
    }

    // safetyCheck 스키마 검증
    function validSafetyCheck(sc) {
      return sc is map
        && sc.passed is bool
        && sc.riskLevel in ['LOW','MEDIUM','HIGH','CRITICAL']
        && sc.violations is list
        && sc.violations.size() <= 50
        && sc.violations.all(v =>
            v is map
            && v.violationType is string
            && v.severity in ['LOW','MEDIUM','HIGH','CRITICAL']
            && (!('matchedText' in v) || (v.matchedText is string && v.matchedText.size() <= 200))
          )
        && sc.reviewedBy is string
        && sc.reviewedBy.size() <= 64
        && sc.doubleChecked is bool;
    }

    /* ===== 정책 문서: 서버(Admin SDK) 전용 ===== */
    match /policies/{doc} {
      allow read, write: if false;
    }

    /* ===== generated_content =====
       - 생성: 작성자만, 허용 필드만, 값 검증
       - 읽기: 작성자 또는 관리자
       - 수정: 작성자(pending일 때 일부 필드만), 관리자(검수 필드만)
       - 삭제: 관리자만
    */
    match /generated_content/{id} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && onlyKeysAllowed(
            request.resource.data,
            ['userId','content','category','createdAt','status','userConfirmed']
          )
        && stringMax(request.resource.data.content, 10000)
        && request.resource.data.category is string
        && request.resource.data.category.size() <= 100
        && request.resource.data.status == 'pending'
        && request.resource.data.userConfirmed == false
        && request.resource.data.createdAt is timestamp;

      allow read: if isOwner(resource.data.userId) || isAdmin();

      // 작성자 업데이트: pending일 때 content/category/userConfirmed만
      allow update: if isOwner(resource.data.userId)
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['content','category','userConfirmed'])
        && stringMax(request.resource.data.content, 10000)
        && request.resource.data.category is string
        && request.resource.data.category.size() <= 100
        && boolField(request.resource.data.userConfirmed)
        && request.resource.data.status == resource.data.status
        && request.resource.data.createdAt == resource.data.createdAt
        && !(request.resource.data.keys().hasAny(['safetyCheck']));

      // 관리자 업데이트: 검수 전용 필드만
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['safetyCheck','status'])
        && request.resource.data.status in ['pending','confirmed','blocked']
        && validSafetyCheck(request.resource.data.safetyCheck);

      allow delete: if isAdmin();
    }

    /* ===== violations: 서버 전용 로그 ===== */
    match /violations/{id} {
      allow read, write, delete: if false;
      // 필요 시 운영툴에서만 열려면 아래 주석 해제
      // allow read: if isAdmin();
      // allow create, update, delete: if isAdmin();
    }

    /* ===== users: 클라이언트는 읽기만(자기 것 또는 관리자) ===== */
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update, delete: if false;
    }

    /* ===== posts: 클라이언트는 읽기만(자기 글 또는 관리자) =====
       쓰기는 callable Functions(서버)로만 수행 */
    match /posts/{postId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create, update, delete: if false;
    }

    /* ===== 기타 전부 차단 ===== */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
