rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- 헬퍼 함수들 ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ⭐️ 관리자 이메일 (실제 운영 이메일로 변경 필요)
    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email in [
               'kjk6206@gmail.com'
             ];
    }
    
    // 🔥 사용자 데이터 검증 (더 유연하게 수정)
    function isValidUserDataOnCreate() {
      let data = request.resource.data;
      return data.keys().hasAll(['email']) &&
             data.email is string && data.email.matches('.*@.*');
    }
    
    // 업데이트 시 허용된 필드만 수정하는지 검증
    function isUpdatingAllowedUserFields() {
      let allowedFields = [
        'name', 'position', 'regionMetro', 'regionLocal', 
        'electoralDistrict', 'status', 'updatedAt', 'role'
      ];
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(allowedFields);
    }

    // --- 컬렉션별 보안 규칙 ---

    // 🔥 사용자 프로필 (users) - 수정됨
    match /users/{userId} {
      // 읽기: 본인 또는 관리자만 가능
      allow read: if isOwner(userId) || isAdmin();
      
      // 생성: 본인이면서, 기본 데이터 구조가 유효할 때만 가능
      allow create: if isOwner(userId) && isValidUserDataOnCreate();
      
      // 업데이트: 본인이면서, 허용된 필드만 수정할 때 가능
      allow update: if isOwner(userId) && isUpdatingAllowedUserFields();
      
      // 삭제: 관리자만 가능
      allow delete: if isAdmin();
    }

    // 🔥 게시물 (posts) - userId 필드 사용으로 수정
    match /posts/{postId} {
      // 읽기: 작성자 본인 또는 관리자
      allow read: if isOwner(resource.data.userId) || isAdmin();
      
      // 생성: 작성자 본인만 가능
      allow create: if isAuthenticated() && 
                   request.auth.uid == request.resource.data.userId;
      
      // 업데이트: 작성자 본인만 가능
      allow update: if isOwner(resource.data.userId);
      
      // 삭제: 작성자 본인 또는 관리자
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // 🔥 임시 드래프트나 세션 데이터 (drafts) - 추가
    match /drafts/{draftId} {
      allow read, write: if isAuthenticated() && 
                        request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && 
                   request.auth.uid == request.resource.data.userId;
    }

    // 🔥 생성 메타데이터 (generation_metadata) - 추가
    match /generation_metadata/{metadataId} {
      allow read, write: if isAuthenticated() && 
                        request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && 
                   request.auth.uid == request.resource.data.userId;
    }

    // 사용량 기록 - 클라이언트 접근 차단
    match /usage_logs/{logId} { 
      allow read, write: if false; 
    }
    match /usage_limits/{limitId} { 
      allow read, write: if false; 
    }

    // 시스템 설정 - 관리자만 접근
    match /system_config/{configId} {
      allow read, write: if isAdmin();
    }

    // 🔥 관리자 전용 컬렉션
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}